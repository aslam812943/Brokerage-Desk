DATABASE_URL="postgresql://brokerage:brokerage@127.0.0.1:5433/brokerage?schema=public"
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Used only by prisma/seed.mjs to create the initial accounts.
# Remove this file's real values from disk after seeding, or rotate the passwords via the app.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
SEED_VIEWER_USERNAME="viewer"
SEED_VIEWER_PASSWORD=""
